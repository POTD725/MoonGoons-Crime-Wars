extends Node
## Embedded compact copy of the user-provided MoonGoons officer rank roster.
## Stored as WebP bytes so the roster console works from a clean Git checkout.

const DATA: String = ""

var texture: Texture2D

func get_texture() -> Texture2D:
	if texture != null:
		return texture
	var image: Image = Image.new()
	var bytes: PackedByteArray = Marshalls.base64_to_raw(DATA)
	var result: Error = image.load_webp_from_buffer(bytes)
	if result != OK:
		return null
	texture = ImageTexture.create_from_image(image)
	return texture
