; MoonGoons: Crime Wars
; Godot 4 RTS foundation

config_version=5

[application]
config/name="MoonGoons: Crime Wars"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7")

[autoload]
DevCheats="*res://dev_cheats.gd"
CutsceneDirector="*res://cutscene_director.gd"
CutsceneSupport="*res://cutscene_support.gd"
CampaignData="*res://story_campaign.gd"
GameProfile="*res://game_profile.gd"
RaceCatalog="*res://race_catalog.gd"
RaceSpecs="*res://race_specs.gd"
RaceMode="*res://race_mode.gd"
PvpMaps="*res://pvp_maps.gd"
MapSelector="*res://map_selector.gd"
CustomMatchConfig="*res://custom_match_config.gd"
CustomMatchRuntime="*res://custom_match_runtime.gd"
CustomMatchAI="*res://custom_match_ai.gd"
GameDifficulty="*res://game_difficulty.gd"
DifficultyRuntime="*res://difficulty_runtime.gd"
DifficultyMenu="*res://difficulty_menu.gd"
FreeRoamAlliance="*res://free_roam_alliance.gd"
LanSession="*res://lan_session.gd"
InGameChat="*res://in_game_chat.gd"
GameArtLibrary="*res://game_art_library.gd"
OfficerRosterTexture="*res://officer_roster_texture.gd"
OfficerRoster="*res://officer_roster.gd"
TacticalMeshCatalog="*res://tactical_mesh_catalog.gd"
DossierMeshPreview="*res://dossier_mesh_preview.gd"
PlayerGUI="*res://player_gui.gd"
CommandDeckArt="*res://command_deck_art_overlay.gd"
DemoMissionDirector="*res://demo_mission_director.gd"
ModeHub="*res://mode_hub.gd"

[display]
window/size/viewport_width=1600
window/size/viewport_height=900
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
